{
    "name": "smoothrestaurant/plugin",
    "description": "Restaurant management plugin for WordPress",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "minimum-stability": "stable",
    "require": {
        "php": ">=8.1",
        "composer/installers": "^2.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^1.11",
        "phpstan/extension-installer": "^1.3",
        "szepeviktor/phpstan-wordpress": "^1.3",
        "phpstan/phpstan-strict-rules": "^1.5",
        "squizlabs/php_codesniffer": "^3.9",
        "wp-coding-standards/wpcs": "^3.0",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
        "yoast/phpunit-polyfills": "^2.0",
        "phpunit/php-code-coverage": "^10.1",
        "vimeo/psalm": "^5.24 || ^6.0",
        "ergebnis/composer-normalize": "^2.42"
    },
    "autoload": {
        "psr-4": {
            "SmoothRestaurant\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SmoothRestaurant\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:unit": "phpunit --testsuite Unit",
        "test:integration": "phpunit --testsuite Integration",
        "test:coverage": "phpunit --coverage-html coverage",
        "stan": "phpstan analyse --memory-limit=1G",
        "stan:baseline": "phpstan analyse --generate-baseline --memory-limit=1G",
        "cs:check": "phpcs --standard=WordPress src/ tests/",
        "cs:fix": "phpcbf --standard=WordPress src/ tests/",
        "lint": "@cs:check",
        "lint:fix": "@cs:fix",
        "quality": ["@cs:check", "@stan", "@test"],
        "test:wp-env": "wp-env run tests-cli --env-cwd=wp-content/plugins/smooth-restaurant vendor/bin/phpunit",
        "normalize": "composer normalize"
    },
    "config": {
        "allow-plugins": {
            "composer/installers": true,
            "phpstan/extension-installer": true,
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "ergebnis/composer-normalize": true
        },
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
