{
  "name": "smooth-restaurant",
  "version": "0.1.0",
  "description": "Restaurant management plugin for WordPress",
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "wp-scripts start --hot",
    "build": "npm run build:admin && npm run build:frontend && npm run build:blocks",
    "build:admin": "wp-scripts build --config=webpack.config.js",
    "build:frontend": "wp-scripts build --webpack-src-dir=assets/src/frontend --output-path=assets/build/frontend",
    "build:blocks": "wp-scripts build --webpack-src-dir=assets/src/blocks --output-path=assets/build/blocks",
    "test:js": "wp-scripts test-unit-js --config=jest.config.js",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "lint:js": "wp-scripts lint-js",
    "lint:css": "wp-scripts lint-style",
    "lint:md:docs": "wp-scripts lint-md-docs",
    "lint:pkg-json": "wp-scripts lint-pkg-json",
    "format": "wp-scripts format",
    "packages-update": "wp-scripts packages-update",
    "i18n:pot": "wp i18n make-pot . languages/smooth-restaurant.pot --domain=smooth-restaurant --exclude=node_modules,vendor,assets/build,tests",
    "i18n:json": "wp i18n make-json languages --no-purge",
    "i18n": "npm run i18n:pot && npm run i18n:json",
    "env:start": "wp-env start",
    "env:stop": "wp-env stop",
    "env:clean": "wp-env clean all"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@hookform/resolvers": "^3.4.0",
    "@tanstack/react-query": "^5.40.0",
    "@wordpress/api-fetch": "^7.0.0",
    "@wordpress/components": "^28.0.0",
    "@wordpress/compose": "^7.0.0",
    "@wordpress/data": "^10.0.0",
    "@wordpress/element": "^6.0.0",
    "@wordpress/hooks": "^4.0.0",
    "@wordpress/i18n": "^5.0.0",
    "@wordpress/notices": "^5.0.0",
    "@wordpress/url": "^4.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "lucide-react": "^1.16.0",
    "next-themes": "^0.4.6",
    "qrcode.react": "^3.1.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-hook-form": "^7.51.0",
    "react-router-dom": "^6.30.3",
    "react-to-print": "^2.15.0",
    "shadcn": "^4.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.6.1",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.23.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@tailwindcss/forms": "^0.5.0",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^15.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.12.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@wordpress/env": "^10.0.0",
    "@wordpress/scripts": "^28.0.0",
    "autoprefixer": "^10.4.0",
    "lighthouse": "^12.0.0",
    "postcss": "^8.4.0",
    "sass": "^1.77.0",
    "tailwindcss": "^3.4.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.4.0"
  }
}
